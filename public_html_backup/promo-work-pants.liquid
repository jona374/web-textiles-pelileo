{% comment %}
  Section: Promo Work Pants (Premium Redesign)
  Description: A high-end, conversion-focused hero section for men's workwear.
  Features modern typography, premium spacing, and an elegant offer presentation.
{% endcomment %}

{%- style -%}
  .promo-hero-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family, 'Helvetica Neue', Arial, sans-serif);
    color: {{ section.settings.text_color }};
    overflow: hidden;
  }

  .promo-hero-container-{{ section.id }} {
    max-width: 540px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* --- HEADER AREA --- */
  .promo-hero-header-{{ section.id }} {
    text-align: center;
    margin-bottom: 2rem;
    width: 100%;
  }

  .promo-hero-title-{{ section.id }} {
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    color: {{ section.settings.title_color }};
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.02em; /* Modern, tight typography */
  }

  .promo-hero-subtitle-{{ section.id }} {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.2em; /* Wide spacing for premium feel */
    color: {{ section.settings.subtitle_color }};
    text-transform: uppercase;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .promo-hero-subtitle-{{ section.id }}::before,
  .promo-hero-subtitle-{{ section.id }}::after {
    content: '';
    display: block;
    width: 20px;
    height: 1px;
    background-color: {{ section.settings.subtitle_color }};
    opacity: 0.5;
  }

  /* --- PRODUCT IMAGE --- */
  .promo-hero-image-wrapper-{{ section.id }} {
    width: 100%;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12); /* Deep, soft premium shadow */
    margin-bottom: -1.5rem; /* Pulls the offer card up to overlap slightly */
    z-index: 1;
    background-color: #f7f7f7;
  }

  .promo-hero-image-wrapper-{{ section.id }}::after {
    /* Subtle inner shadow for depth */
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: 16px;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.04);
    pointer-events: none;
  }

  .promo-hero-img-{{ section.id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .promo-hero-image-wrapper-{{ section.id }}:hover .promo-hero-img-{{ section.id }} {
    transform: scale(1.04);
  }

  /* --- OFFER CARD --- */
  .promo-hero-offer-{{ section.id }} {
    background-color: {{ section.settings.offer_bg_color }};
    width: 90%; /* Creates a nice framing effect over the image */
    max-width: 420px;
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-align: center;
    position: relative;
    z-index: 2;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); /* Lifted appearance */
    border: 1px solid rgba(0,0,0,0.05); /* Crisp edge */
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  .promo-hero-offer-text-{{ section.id }} {
    font-size: 1rem;
    font-weight: 700;
    color: {{ section.settings.offer_text_color }};
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.5rem 0;
    opacity: 0.9;
  }

  .promo-hero-price-{{ section.id }} {
    font-size: 3.5rem;
    font-weight: 900;
    color: {{ section.settings.price_color }};
    line-height: 1;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.03em;
  }

  .promo-hero-unit-{{ section.id }} {
    font-size: 0.85rem;
    font-weight: 600;
    color: {{ section.settings.unit_price_color }};
    margin: 0;
    opacity: 0.8;
  }

  /* --- CTA BUTTON --- */
  .promo-hero-cta-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background-color: {{ section.settings.btn_color }};
    color: {{ section.settings.btn_text_color }};
    padding: 18px 24px;
    border-radius: 8px; /* Square with slight rounding is very modern-commercial */
    text-decoration: none;
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    box-shadow: 0 4px 14px {{ section.settings.btn_color | color_modify: 'alpha', 0.4 }};
  }

  .promo-hero-cta-{{ section.id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px {{ section.settings.btn_color | color_modify: 'alpha', 0.6 }};
    color: {{ section.settings.btn_text_color }};
  }

  .promo-hero-cta-icon-{{ section.id }} {
    width: 22px;
    height: 22px;
    margin-right: 10px;
    fill: currentColor;
  }

  /* --- RESPONSIVE --- */
  @media screen and (min-width: 769px) {
    .promo-hero-container-{{ section.id }} {
      max-width: 600px;
    }
    .promo-hero-title-{{ section.id }} {
      font-size: 4rem;
    }
    .promo-hero-offer-{{ section.id }} {
      padding: 2.5rem 2rem;
    }
  }
{%- endstyle -%}

<section class="promo-hero-{{ section.id }}">
  <div class="promo-hero-container-{{ section.id }}">
    
    <!-- Title Section -->
    <div class="promo-hero-header-{{ section.id }}">
      {% if section.settings.title != blank %}
        <h1 class="promo-hero-title-{{ section.id }}">{{ section.settings.title }}</h1>
      {% endif %}
      
      {% if section.settings.subtitle != blank %}
        <h2 class="promo-hero-subtitle-{{ section.id }}">{{ section.settings.subtitle }}</h2>
      {% endif %}
    </div>

    <!-- Image Section -->
    <div class="promo-hero-image-wrapper-{{ section.id }}">
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | img_url: '1000x' }}" 
          alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
          class="promo-hero-img-{{ section.id }}"
          loading="eager"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'promo-hero-img-' | append: section.id }}
      {% endif %}
    </div>

    <!-- Offer & Price Card (Overlaps image slightly) -->
    <div class="promo-hero-offer-{{ section.id }}">
      {% if section.settings.offer_text != blank %}
        <p class="promo-hero-offer-text-{{ section.id }}">{{ section.settings.offer_text }}</p>
      {% endif %}
      
      {% if section.settings.promotional_price != blank %}
        <div class="promo-hero-price-{{ section.id }}">{{ section.settings.promotional_price }}</div>
      {% endif %}
      
      {% if section.settings.unit_price_text != blank %}
        <p class="promo-hero-unit-{{ section.id }}">{{ section.settings.unit_price_text }}</p>
      {% endif %}
    </div>

    <!-- Call to Action Button -->
    {%- assign whatsapp_link = section.settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' -%}
    {%- if section.settings.whatsapp_message != blank -%}
      {%- assign whatsapp_url = 'https://wa.me/' | append: whatsapp_link | append: '?text=' | append: section.settings.whatsapp_message | url_encode -%}
    {%- else -%}
      {%- assign whatsapp_url = 'https://wa.me/' | append: whatsapp_link -%}
    {%- endif -%}

    <a href="{{ whatsapp_url }}" class="promo-hero-cta-{{ section.id }}" target="_blank" rel="noopener noreferrer">
      <svg class="promo-hero-cta-icon-{{ section.id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
      {{ section.settings.btn_text }}
    </a>

  </div>
</section>

{% schema %}
{
  "name": "Promo Especial Premium",
  "settings": [
    {
      "type": "header",
      "content": "Información del Producto"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título Principal",
      "default": "PANTALÓN DE TRABAJO"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "PREMIUM | PARA HOMBRE"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fotografía del Producto",
      "info": "Recomendado: 800x1000px o formato cuadrado con fondo limpio."
    },
    {
      "type": "header",
      "content": "Bloque de Oferta"
    },
    {
      "type": "text",
      "id": "offer_text",
      "label": "Etiqueta Superior",
      "default": "LLEVA 3 X"
    },
    {
      "type": "text",
      "id": "promotional_price",
      "label": "Precio Gigante",
      "default": "$39,99"
    },
    {
      "type": "text",
      "id": "unit_price_text",
      "label": "Texto Secundario (Precio Unitario)",
      "default": "PRECIO UNITARIO: $15,00"
    },
    {
      "type": "header",
      "content": "Botón de Acción (WhatsApp)"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto del Botón",
      "default": "PEDIR AHORA"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "Número de WhatsApp",
      "default": "593999999999",
      "info": "Incluye el código de país sin el símbolo +. Ej: 593987654321"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "Mensaje Predeterminado",
      "default": "Hola, estoy interesado en la promoción de los Pantalones de Trabajo."
    },
    {
      "type": "header",
      "content": "Diseño y Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de la Sección",
      "default": "#F8F9FA",
      "info": "Un gris muy suave o blanco da un aspecto limpio."
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del Título",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Color del Subtítulo",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "offer_bg_color",
      "label": "Fondo del Bloque de Oferta",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "offer_text_color",
      "label": "Texto Superior (Lleva 3x)",
      "default": "#4B5563"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Color del Precio Gigante",
      "default": "#0F172A"
    },
    {
      "type": "color",
      "id": "unit_price_color",
      "label": "Texto Inferior (Precio ud)",
      "default": "#6B7280"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Color Botón WhatsApp",
      "default": "#25D366"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Color Texto Botón",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espaciados"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margen Superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margen Inferior",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Promo Especial Premium",
      "category": "Conversión"
    }
  ]
}
{% endschema %}
